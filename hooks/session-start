#!/usr/bin/env bash
# Session-start hook for Moberg toolkit
# Detects platform and emits appropriate context format
# Supports: Claude Code, Cursor, Copilot CLI, Gemini CLI

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="${SCRIPT_DIR}/.."

# Build MCP server on first use (silent, non-blocking)
# If dist/ is missing and node is available, build it.
# MCP is optional — all skills have bash fallbacks (S3.12).
if [ ! -f "$PLUGIN_ROOT/dist/mtk-mcp-server.cjs" ] && [ -d "$PLUGIN_ROOT/mcp" ]; then
  if command -v node >/dev/null 2>&1; then
    bash "$PLUGIN_ROOT/scripts/build-mcp.sh" --quiet 2>/dev/null || true
  fi
fi

# Check for in-progress specs and plans (session recovery)
RECOVERY_MSG=""
if [[ -d "docs/specs" ]]; then
  RECENT_SPEC="$(find docs/specs -name '*.md' -mtime -1 2>/dev/null | head -1)"
  if [[ -n "$RECENT_SPEC" ]]; then
    RECOVERY_MSG="SESSION RECOVERY: Found recent spec at ${RECENT_SPEC}. You may have an in-progress feature. Read the spec to resume where you left off."
  fi
fi
if [[ -d "docs/plans" ]] && [[ -z "$RECOVERY_MSG" ]]; then
  RECENT_PLAN="$(find docs/plans -name '*.md' -mtime -1 2>/dev/null | head -1)"
  if [[ -n "$RECENT_PLAN" ]]; then
    RECOVERY_MSG="SESSION RECOVERY: Found recent plan at ${RECENT_PLAN}. You may have an in-progress implementation. Read the plan and tasks/todo.md to resume."
  fi
fi
if [[ -f "tasks/todo.md" ]] && [[ -z "$RECOVERY_MSG" ]]; then
  if grep -q '\[ \]' tasks/todo.md 2>/dev/null; then
    RECOVERY_MSG="SESSION RECOVERY: Found incomplete tasks in tasks/todo.md. Check for in-progress work before starting something new."
  fi
fi

# Version drift check (advisory only)
VERSION_MSG=""
if [ -f .claude/mtk-version.json ]; then
  INSTALLED_VERSION="$(grep -o '"version":"[^"]*"' .claude/mtk-version.json 2>/dev/null | sed 's/"version":"//;s/"//' || true)"
  if [ -n "$INSTALLED_VERSION" ] && [ -n "${CLAUDE_PLUGIN_ROOT:-}" ]; then
    SOURCE_MANIFEST="${CLAUDE_PLUGIN_ROOT}/.claude/manifest.json"
    if [ -f "$SOURCE_MANIFEST" ]; then
      SOURCE_VERSION="$(grep -o '"version": "[^"]*"' "$SOURCE_MANIFEST" | head -1 | sed 's/"version": "//;s/"//' || true)"
      if [ -n "$SOURCE_VERSION" ] && [ "$INSTALLED_VERSION" != "$SOURCE_VERSION" ]; then
        VERSION_MSG="MTK update available: ${INSTALLED_VERSION} → ${SOURCE_VERSION}. Run /mtk:setup-update to sync."
      fi
    fi
  fi
fi

# Build the context message
BASE_MSG="Moberg toolkit is active. Available commands: implement, fix, pre-commit-review, setup-bootstrap, setup-audit, setup-update. Skills loaded on demand via progressive disclosure."
CONTEXT="$BASE_MSG"
[[ -n "$RECOVERY_MSG" ]] && CONTEXT="${CONTEXT} ${RECOVERY_MSG}"
[[ -n "$VERSION_MSG" ]] && CONTEXT="${CONTEXT} ${VERSION_MSG}"

# Escape for JSON (bash parameter substitution — no external deps)
json_escape() {
  local s="$1"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  s="${s//$'\n'/\\n}"
  s="${s//$'\t'/\\t}"
  printf '%s' "$s"
}

ESCAPED_CONTEXT="$(json_escape "$CONTEXT")"

# Platform detection and output routing
if [[ -n "${CURSOR_PLUGIN_ROOT:-}" ]]; then
  # Cursor format
  printf '{"context": "%s"}\n' "$ESCAPED_CONTEXT"
elif [[ -n "${CLAUDE_PLUGIN_ROOT:-}" ]] && [[ -z "${COPILOT_CLI:-}" ]]; then
  # Claude Code format
  printf '{"context": "%s"}\n' "$ESCAPED_CONTEXT"
elif [[ -n "${COPILOT_CLI:-}" ]]; then
  # GitHub Copilot CLI — SDK standard format
  printf '{"role": "system", "content": "%s"}\n' "$ESCAPED_CONTEXT"
elif [[ -n "${GEMINI_EXTENSION_ROOT:-}" ]]; then
  # Gemini CLI format
  printf '{"context": "%s"}\n' "$ESCAPED_CONTEXT"
else
  # Unknown platform — SDK standard format as fallback
  printf '{"role": "system", "content": "%s"}\n' "$ESCAPED_CONTEXT"
fi

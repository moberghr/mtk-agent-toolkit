#!/usr/bin/env bash
# Stop hook: flags completion claims that lack command output evidence.
# The error message is a prompt — it tells the agent exactly what to do next.
# Prints actionable guidance if triggered, nothing otherwise.
set -euo pipefail

MSG="$*"

# Does the message claim completion?
if echo "$MSG" | grep -qiE '\b(done|complete[d]?|fixed|verified|finished)\b'; then
  # Does it also contain command output evidence? (exit codes, test counts, build results, shell prompts)
  if echo "$MSG" | grep -qE '(exit code|passed|failed|error[s]? [0-9]|warning[s]? [0-9]|Build succeeded|PASSED|FAILED|\$ |```|test[s]? ran)'; then
    exit 0
  fi
  echo "VERIFICATION GAP: Run the verification command from your active tech stack and cite its output before reporting done. The build and test commands are in .claude/skills/tech-stack-{stack}/SKILL.md (## Build & Test Commands). For toolkit work: run 'bash scripts/validate-toolkit.sh' and cite 'Toolkit validation passed.' For fixes: run the specific reproduction step. Cite exit code and pass/fail counts."
fi
